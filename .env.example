# ===========================================
# BizBranches - Environment Variables
# NEVER commit .env or real secrets.
# ===========================================

# First-time local: npm run setup:local  (creates frontend/.env.local + backend-php/.env from templates)
#
# ─── FRONTEND (frontend/.env.local) ──────────────────────
# On cPanel: both frontend and backend share the same domain
# BACKEND_URL points to the same domain (Apache routes /api/* to PHP)
NEXT_PUBLIC_BACKEND_URL=http://localhost:3002
BACKEND_URL=http://localhost:3002
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
NEXT_PUBLIC_SITE_URL=https://bizbranches.pk
# NEXT_PUBLIC_ENABLE_COPY_DETERRENT=true   # optional: block right-click / F12; default off so dev tools work

# Admin UI (/admin) — server-only; must match backend-php ADMIN_SECRET for API proxy
# ADMIN_PANEL_PASSWORD=your_strong_password   # sign-in form; falls back to ADMIN_SECRET if unset
# ADMIN_SECRET=your_admin_secret
# Optional: hide default /admin and use a private path instead (example: /a9d3-admin-panel)
# NEXT_PUBLIC_ADMIN_PATH=/control-room-9x7k

# ─── PHP BACKEND (api/.env on cPanel) ────────────────────
# See backend-php/.env.example for full backend config

# ─── PRODUCTION (cPanel single-domain setup) ─────────────
# BACKEND_URL=https://bizbranches.pk
# NEXT_PUBLIC_BACKEND_URL=https://bizbranches.pk
# SITE_URL=https://bizbranches.pk
# CPANEL_DEPLOY=true

# ─── DEPLOY ──────────────────────────────────────────────
# No GitHub Actions in this repo: build locally, zip/upload per CPANEL_DEPLOYMENT.md
