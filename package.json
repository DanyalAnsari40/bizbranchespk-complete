{
  "name": "bizbranches-combined",
  "version": "1.0.0",
  "private": true,
  "description": "BizBranches - Next.js frontend + PHP backend (MySQL)",
  "scripts": {
    "setup:local": "node scripts/setup-local.cjs",
    "dev": "concurrently \"npm run start:backend-php\" \"npm run dev:frontend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "npm install && cd frontend && npm install && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "start": "sh start-php.sh",
    "start:frontend": "cd frontend && npm run start",
    "start:backend-php": "cd backend-php && php -S 0.0.0.0:3002 index.php",
    "install:all": "npm install && cd frontend && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "mongodb": "^6.21.0"
  }
}
