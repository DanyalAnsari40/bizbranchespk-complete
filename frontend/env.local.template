# Copy to .env.local (or run: npm run setup:local from repo root)
# Next.js dev: rewrites /api → PHP on :3002 — do NOT set NEXT_PUBLIC_STATIC_EXPORT here.

NEXT_PUBLIC_BACKEND_URL=http://localhost:3002
BACKEND_URL=http://localhost:3002
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: Cloudinary (needed for image uploads in dev)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
