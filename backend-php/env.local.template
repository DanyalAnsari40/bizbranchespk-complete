# Copy to .env (or run: npm run setup:local from repo root)
# Adjust DB_* to match your local MySQL, then import migrations/001_create_tables.sql

APP_ENV=local
DISABLE_CACHE=1

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=bizbranches_local
DB_USER=root
DB_PASS=

ADMIN_SECRET=dev_admin_secret_change_me

SITE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Optional Cloudinary (match frontend NEXT_PUBLIC_CLOUDINARY_*)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# SMTP optional for local email tests
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=dev@localhost
EMAIL_FROM_NAME=BizBranches Dev
SUPPORT_EMAIL=dev@localhost
